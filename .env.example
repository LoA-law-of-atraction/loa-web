NEXT_PUBLIC_FIREBASE_API_KEY= 
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN= 
NEXT_PUBLIC_FIREBASE_PROJECT_ID= 
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET= 
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID= 
NEXT_PUBLIC_FIREBASE_APP_ID= 
NEXT_PUBLIC_META_PIXEL_ID= 
NEXT_PUBLIC_ADMIN_EMAIL=
ADMIN_EMAIL=

# Blog API Key for automation (generate with: openssl rand -hex 32)
BLOG_API_KEY=

# Firebase Admin SDK (for server-side operations)
# Option 1: Full service account JSON (recommended for Vercel)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Option 2: Individual values (alternative)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

FAL_API_KEY=
ELEVENLABS_API_KEY=
SHOTSTACK_API_KEY=
# Optional: film grain overlay for quote-videos assemble (HTTPS URL to image or short loop video)
QUOTE_VIDEOS_GRAIN_OVERLAY_URL=
ANTHROPIC_API_KEY=
NEXT_PUBLIC_BASE_URL=

# Optional: shown on /contact-us (legal transparency, E-E-A-T)
NEXT_PUBLIC_COMPANY_LEGAL_NAME=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_COMPANY_REGISTRATION_NUMBER=

# IndexNow (Bing/Yandex): key must match public/{INDEXNOW_KEY}.txt — see docs/seo/ACTION-PLAN.md H12
INDEXNOW_KEY=
# Optional: require Authorization: Bearer <secret> on POST /api/indexnow
INDEXNOW_SUBMIT_SECRET=

# AI Model Configuration
NEXT_PUBLIC_CLAUDE_MODEL=claude-sonnet-4-20250514

FAL_VEO_MODEL=fal-ai/veo3.1/fast/image-to-video
FAL_MULTIPLE_ANGLES_MODEL=fal-ai/flux-2-lora-gallery/multiple-angles

# Music generation models (Step 5) – endpoints and costs
FAL_MUSIC_MODEL_ELEVENLABS=fal-ai/elevenlabs/music
FAL_MUSIC_MODEL_STABLE_AUDIO_25=fal-ai/stable-audio-25/text-to-audio
FAL_MUSIC_MODEL_BEATOVEN=beatoven/music-generation
# Costs (optional – used if Fal pricing API doesn't return them)
FAL_MUSIC_COST_ELEVENLABS_PER_MIN=0.8
FAL_MUSIC_COST_STABLE_AUDIO_25=0.2
FAL_MUSIC_COST_BEATOVEN=0.1
# Legacy alias for ElevenLabs (overrides FAL_MUSIC_COST_ELEVENLABS_PER_MIN if set)
FAL_ELEVENLABS_MUSIC_COST_PER_MINUTE=0.8
# Quote Videos – display names for UI (no hardcoded model names)
# Step 1: Claude (extract quotes). Step 2: Claude (image→prompt / reference analysis) + Fal (image gen). Same Claude pricing as Step 1.
NEXT_PUBLIC_QUOTE_CLAUDE_MODEL_LABEL=Claude Sonnet 4
NEXT_PUBLIC_QUOTE_IMAGE_MODEL_LABEL=Fal Flux Schnell
NEXT_PUBLIC_QUOTE_VIDEO_MODEL_LABEL=Fal (image-to-video)
NEXT_PUBLIC_QUOTE_RENDER_SERVICE_LABEL=Shotstack
# Quote Videos – Step 2 text-to-image model selector. Options: comma-separated "id|Label|bodyType". bodyType = grok | nano_banana. Default: use value below or first option.
NEXT_PUBLIC_QUOTE_VIDEOS_TEXT_TO_IMAGE_MODEL_OPTIONS=xai/grok-imagine-image|xAI Grok Imagine|grok,fal-ai/nano-banana-pro|Fal Nano Banana Pro|nano_banana
NEXT_PUBLIC_QUOTE_VIDEOS_IMAGE_MODEL_DEFAULT=xai/grok-imagine-image
# Quote Videos – Step 2 (generate image). Optional; if unset, step 2 cost shows as 0.
FAL_QUOTE_IMAGE_COST=
# Quote Videos – Step 3 (generate video from image). Optional; if unset, step 3 cost shows as 0.
FAL_QUOTE_VIDEO_COST=

# API Pricing (update based on actual pricing)
# Claude AI - Sonnet 4 pricing per million tokens
NEXT_PUBLIC_CLAUDE_INPUT_PER_MILLION=3.00
NEXT_PUBLIC_CLAUDE_OUTPUT_PER_MILLION=15.00

# ElevenLabs - Subscription-based pricing
# Charged by characters/credits (not API calls): ~1 credit = 1 character (standard) | ~1.2-2x (Turbo)
# Plans: Free: $0/10k | Starter: $5/30k | Creator: $11-22/100k | Pro: $99/500k | Scale: $330/2M
# Within plan limits, calculate: (monthly_cost / included_credits) * 1000
# Example: Starter $5/30k = $0.167/1k | Creator $22/100k = $0.22/1k | Pro $99/500k = $0.198/1k
# Overage rates (beyond limits): Creator: $0.30/1k | Pro: $0.24/1k | Scale: $0.18/1k
ELEVENLABS_PLAN_COST=5.00
ELEVENLABS_PLAN_CREDITS=30000
ELEVENLABS_OVERAGE_PER_1000_CHARS=0.30

# Shotstack - per render minute
SHOTSTACK_PER_MINUTE=0.05

# Step 7: Post to social (optional – omit to disable)
# Instagram OAuth: set both, then open /api/auth/instagram to connect
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
# Instagram manual (overrides OAuth if set): user id + long-lived token from Meta
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Webhook only if Meta requires it: callback URL = /api/webhooks/instagram, set same value here
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
# Debug: set to 1 to include full access_token in API debug responses (local only)
# INSTAGRAM_DEBUG_SHOW_TOKEN=
# YouTube: optional manual token; or use OAuth below (Connect YouTube in Step 7)
YOUTUBE_ACCESS_TOKEN=
# YouTube OAuth (recommended): Google Cloud OAuth 2.0 Client ID + Secret; add redirect URI: <BASE_URL>/api/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: YOUTUBE_REDIRECT_URI, YOUTUBE_SUCCESS_REDIRECT; YOUTUBE_DEBUG_SHOW_TOKEN=1 for debug
# TikTok: user token with video.upload scope (PULL_FROM_URL; verify video URL domain in TikTok)
TIKTOK_ACCESS_TOKEN=
NEXT_PUBLIC_REVENUECAT_WEB_API_KEY=
# Server-side: REST API secret (Project settings → API keys → Secret) for subscriber tier + quotas
REVENUECAT_API_SECRET=
# Optional: entitlement identifiers if not "basic" / "pro"
# REVENUECAT_ENTITLEMENT_BASIC=basic
# REVENUECAT_ENTITLEMENT_PRO=pro